{
  "name": "ung_dung_cdss_bhyt",
  "description": "CDSS BHYT — hỗ trợ giám định hồ sơ BHYT (web + mobile + desktop đóng gói).",
  "author": "BV Phương Châu",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --port 8081",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android --port 8081",
    "ios": "expo start --ios --port 8081",
    "web": "expo start --web --port 8081",
    "py:install": "python -m pip install -r python_service/requirements.txt",
    "py:start": "python -m uvicorn python_service.app.main:app --host 0.0.0.0 --port 8000 --reload",
    "qa:python-service": "node ./scripts/smoke_test_python_service.js",
    "lint": "expo lint && npm run -s encoding:check && npm run -s font:check",
    "encoding:fix": "node ./scripts/fix-mojibake-lines.js --write",
    "encoding:check": "node ./scripts/check-mojibake.js",
    "vi:check": "node ./scripts/check-vietnamese-diacritics.js",
    "font:check": "node ./scripts/check-font-standards.js",
    "text:check": "npm run -s encoding:check && npm run -s vi:check && npm run -s font:check",
    "firebase:deploy-rules": "npx firebase-tools deploy --project bhyt-cdss --only firestore:rules",
    "firebase:emulators": "npx firebase-tools emulators:start --project bhyt-cdss --only firestore",
    "firebase:set-claims": "node ./scripts/firebase-set-custom-claims.js",
    "qa:xml-real": "node ./scripts/test-xml-real-data.js",
    "qa:strict-flow": "node ./scripts/check-strict-manual-workflow.js",
    "qa:claim-audit": "node ./scripts/run_claim_audit.js",
    "qa:audit-fixtures": "node ./scripts/qa_audit_fixtures.js",
    "qa:on-off-match": "node ./scripts/qa_on_off_match.mjs",
    "desktop:export": "expo export --platform web",
    "desktop:electron": "electron ./electron-main.cjs",
    "desktop:pack": "npm run desktop:export && node scripts/stage_desktop_pack.mjs --",
    "desktop:build:win": "npm run desktop:export && node scripts/stage_desktop_pack.mjs -- --win",
    "desktop:build:mac": "npm run desktop:export && node scripts/stage_desktop_pack.mjs -- --mac",
    "desktop:build:linux": "npm run desktop:export && node scripts/stage_desktop_pack.mjs -- --linux"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-admin": "^13.0.0",
    "playwright": "^1.59.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
