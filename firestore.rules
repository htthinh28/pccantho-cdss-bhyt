rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userOrgId() {
      return signedIn() ? request.auth.token.org_id : null;
    }

    function hasRole(roles) {
      return signedIn() && request.auth.token.role in roles;
    }

    function isSameOrg(orgId) {
      return signedIn() && userOrgId() == orgId;
    }

    function canReadOrg(orgId) {
      return isSameOrg(orgId) && hasRole(['ADMIN', 'AUDITOR', 'OPERATOR', 'REVIEWER', 'USER']);
    }

    function canWriteOrg(orgId) {
      return isSameOrg(orgId) && hasRole(['ADMIN', 'AUDITOR', 'OPERATOR']);
    }

    function canAdminOrg(orgId) {
      return isSameOrg(orgId) && hasRole(['ADMIN']);
    }

    match /orgs/{orgId} {
      allow read: if canReadOrg(orgId);
      allow write: if canAdminOrg(orgId);

      match /claim_documents/{docId} {
        allow read: if canReadOrg(orgId);
        allow create: if canWriteOrg(orgId)
          && request.resource.data.doc_id is string
          && request.resource.data.ma_lk is string
          && request.resource.data.storage_path is string
          && request.resource.data.file_name is string;
        allow update: if canWriteOrg(orgId);
        allow delete: if canAdminOrg(orgId);
      }

      match /claim_document_chunks/{chunkId} {
        allow read: if canReadOrg(orgId);
        allow create, update: if canWriteOrg(orgId)
          && request.resource.data.parent_id is string
          && request.resource.data.chunk_index is int
          && request.resource.data.chunk_data is string;
        allow delete: if canWriteOrg(orgId);
      }

      match /claim_results/{docId} {
        allow read: if canReadOrg(orgId);
        allow create: if canWriteOrg(orgId)
          && request.resource.data.claim_id is string
          && request.resource.data.storage_path is string;
        allow update: if canWriteOrg(orgId);
        allow delete: if canAdminOrg(orgId);
      }

      match /claim_result_chunks/{chunkId} {
        allow read: if canReadOrg(orgId);
        allow create, update: if canWriteOrg(orgId)
          && request.resource.data.parent_id is string
          && request.resource.data.chunk_index is int
          && request.resource.data.chunk_data is string;
        allow delete: if canWriteOrg(orgId);
      }

      match /dvkt_datasets/{datasetKey} {
        allow read: if canReadOrg(orgId);
        allow create, update: if canWriteOrg(orgId)
          && request.resource.data.dataset_key is string
          && request.resource.data.storage_path is string;
        allow delete: if canAdminOrg(orgId);
      }

      match /dvkt_dataset_chunks/{chunkId} {
        allow read: if canReadOrg(orgId);
        allow create, update: if canWriteOrg(orgId)
          && request.resource.data.parent_id is string
          && request.resource.data.chunk_index is int
          && request.resource.data.chunk_data is string;
        allow delete: if canWriteOrg(orgId);
      }

      /** Khóa phiên đồng bộ cấu hình (transaction client); TTL trong lock_expires_at_ms */
      match /system_config/{docId} {
        allow read: if canReadOrg(orgId);
        allow create, update: if canWriteOrg(orgId);
        allow delete: if canAdminOrg(orgId);
      }

      /** Nhật ký đồng bộ — chỉ thêm (append-only), không cho client sửa/xóa nhật ký */
      match /audit_config_sync/{docId} {
        allow read: if canReadOrg(orgId);
        allow create: if canWriteOrg(orgId)
          && request.resource.data.action is string
          && request.resource.data.actor_uid is string;
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
