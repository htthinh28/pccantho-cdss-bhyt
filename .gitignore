# dependencies
node_modules/

# Expo
.expo/
dist/
packaging/out_portable/
web-build/
# Bản HTML sinh từ tai_lieu/ (npm run tai_lieu:prepare)
public/tai_lieu/
release-desktop/
# Gói zip cập nhật offline (có thể rất lớn; giữ .gitkeep trong offline_update_packs/)
offline_update_packs/*.zip
.desktop-staging/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android

# Firebase Admin SDK keys (KHÔNG bao giờ push lên git)
tai_nguyen/*.json
# Tài nguyên nội bộ: hồ sơ XML thật + PDF (gốc và thư mục con)
tai_nguyen/*.xml
tai_nguyen/**/*.xml
tai_nguyen/*.pdf
tai_nguyen/**/*.pdf

# XML hồ sơ thật đặt trực tiếp trong test_xml/ (fixture huấn luyện đặt trong test_xml/huan_luyen/)
test_xml/*.xml
!test_xml/claim_audit_smoke.xml

# Chỉ mục sinh từ hồ sơ thật (MA_LK, đường dẫn file — chỉ giữ cục bộ)
tai_lieu/_index_tai_nguyen*.json
tai_lieu/_index_kho_huan_luyen*.json
# Gộp báo cáo vi phạm + MA_LK + đường dẫn XML (chỉ giữ cục bộ)
tai_lieu/_huan_luyen_merge_audit_neo_ip.json
tai_lieu/_huan_luyen_merge_*.json

# File tạm / quét rule cục bộ
tmp_*
temp_rule_scan*.txt
.tmp_web_export/
.tmp_*/
.tmp_*.jsx
firebase-debug.log
.firebaserc
full_source_code.txt
__pycache__/
*.pyc

# Local agent / IDE state (không đồng bộ)
.openclaw/
memory/

# Log cục bộ
server.log

# File tạm extract (không cần trong repo)
temp_*_extract*.txt

# Binary đóng gói / phân phối (không đồng bộ git: exe, zip, gói cài đặt)
*.exe
*.msi
*.zip
*.7z
*.rar
*.dmg
*.AppImage

# Dataset SFT sinh từ script (có thể lớn / nhạy cảm nội bộ)
training_data/generated/
